# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
# This file holds NON-SECRET config only. The two secret variables
# (github_token, slack_signing_secret) MUST be supplied via env vars at
# apply time so they never land on disk:
#
#   read -rs TF_VAR_github_token; export TF_VAR_github_token
#   read -rs TF_VAR_slack_signing_secret; export TF_VAR_slack_signing_secret
#   terraform apply

github_owner    = "my-org"
github_repo     = "my-repo"
github_workflow = "deploy.yml"

# Defaults you may want to override:
# region        = "eu-west-1"
# aws_profile   = "dangote-dev"
# function_name = "slack-deploy"
# name_prefix   = "slack-deploy"
